# pyenv
#   For a library or binary, you should probably not check in .python-version
# .python-version

# pipenv
#   According to pypa/pipenv#598, it is recommended to include Pipfile.lock in version control.
#   However, in case of collaboration, if you work with different python versions or platforms,
#   you might want to ignore Pipfile.lock.
# Pipfile.lock

# poetry
#   Similar to Pipenv, it is generally recommended to check poetry.lock into control.
# poetry.lock

# pdm
#   Similar to Pipenv, it is generally recommended to check pdm.lock into control.
# pdm.lock

# PEP 582; used by e.g. github.com/pypa/pdm
